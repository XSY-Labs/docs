{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "YieldPoint",
  "colors": {
    "primary": "#00e606",
    "light": "#00e606",
    "dark": "#008b07"
  },
  "background": {
    "color": {
      "light": "#0F1215",
      "dark": "#0F1215"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": "/logo.svg",
  "redirects": [
    {
      "source": "/protocol/partner-integration",
      "destination": "/protocol/integration/overview",
      "permanent": true
    },
    {
      "source": "/protocol/sdk-integration",
      "destination": "/protocol/integration/overview",
      "permanent": true
    },
    {
      "source": "/protocol/cross-chain",
      "destination": "/protocol/integration/bridge-operations",
      "permanent": true
    }
  ],
  "api": {
    "openapi": "https://api.yieldpoint.io/docs/json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["bash", "javascript", "python"]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Protocol",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "protocol/architecture/overview",
              "protocol/architecture/flows",
              "protocol/architecture/state",
              "protocol/architecture/contracts",
              "protocol/architecture/tokens-and-fees"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "protocol/integration/overview",
              "protocol/integration/base-operations",
              "protocol/integration/bridge-operations",
              "protocol/integration/spoke-chain-operations",
              "protocol/integration/gotchas"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "protocol/security"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "User guides",
            "pages": [
              "guides/coming-soon"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "https://api.yieldpoint.io/docs/json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://paragraph.com/@yieldpoint",
          "icon": "newspaper"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.yieldpoint.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "aistudio",
      "windsurf",
      "mcp",
      "add-mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/xsy_fi",
      "discord": "https://discord.gg/fdxe4efA2M"
    }
  }
}
