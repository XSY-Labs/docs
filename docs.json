{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "YieldPoint",
  "colors": {
    "primary": "#00e606",
    "light": "#00e606",
    "dark": "#008b07"
  },
  "background": {
    "color": {
      "light": "#0F1215",
      "dark": "#0F1215"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": "/logo.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Protocol",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "protocol/architecture/overview",
              "protocol/architecture/flows",
              "protocol/architecture/state",
              "protocol/architecture/contracts",
              "protocol/architecture/tokens-and-fees"
            ]
          },
          {
            "group": "Coming soon",
            "pages": [
              "protocol/cross-chain",
              "protocol/security",
              "protocol/sdk-integration",
              "protocol/partner-integration"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "User guides",
            "pages": [
              "guides/coming-soon"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://paragraph.com/@yieldpoint",
          "icon": "newspaper"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.yieldpoint.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "aistudio",
      "windsurf",
      "mcp",
      "add-mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/xsy_fi",
      "discord": "https://discord.gg/fdxe4efA2M"
    }
  }
}
