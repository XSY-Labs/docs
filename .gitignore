.vscode/
.idea/
*.swp
*.swo
*~

# Node / Mintlify CLI
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Mintlify local build
.mintlify/

# Environment
.env
.env.local
.env.*.local

